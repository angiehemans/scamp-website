{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "scamp-website",
  "compatibility_date": "2026-04-14",
  // Assets-only deployment: Next.js static export (`out/`) is served directly
  // from Cloudflare's edge with no Worker in the request path.
  "assets": {
    "directory": "./out",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  }
}
