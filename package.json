{
  "name": "scamp-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "predev": "node scripts/build-changelog.mjs && node scripts/build-docs.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/build-changelog.mjs && node scripts/build-docs.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
