    "upload": "next build && wrangler versions upload"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.44.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prettier": "3.8.2",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "typescript": "^5",
    "unified": "^11.0.5",
    "wrangler": "^4.82.2"
  }
